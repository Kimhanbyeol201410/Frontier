{
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.firstMeeting.0-0.ancient": "[sine]......?[/sine]",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.firstMeeting.0-0.next": "Continue",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.firstMeeting.0-1.ancient": "[sine]An unfamiliar touch... is this your first time here...?[/sine]",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.firstMeeting.0-1.next": "Nod",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.firstMeeting.0-2.char": "Yes. I fell into this place while asleep on my anvil.",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.firstMeeting.0-2.next": "Reply",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.firstMeeting.0-3.char": "I'm looking for the way [gold]home[/gold].",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.firstMeeting.0-3.next": "Reply",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.firstMeeting.0-4.ancient": "[sine]The way home... with but a single [gold]hammer[/gold] in your hand?[/sine]",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.firstMeeting.0-4.next": "Reply",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.firstMeeting.0-5.char": "One hammer is enough.",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.firstMeeting.0-5.next": "Reply",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.firstMeeting.0-6.char": "[gold]Forging[/gold] always begins with what is already in hand.",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.firstMeeting.0-6.next": "Reply",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.firstMeeting.0-7.ancient": "[sine]Very well... then strike.[/sine]",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.firstMeeting.0-7.next": "Continue",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.firstMeeting.0-8.ancient": "[sine]I shall watch what is engraved upon your [gold]anvil[/gold].[/sine]",

  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.0-0.ancient": "[sine]A touch from another world... how long it has been...[/sine]",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.0-0.next": "Reply",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.0-1.char": "...Just point me the way home.",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.0-1.next": "Reply",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.0-2.char": "One [gold]hammer[/gold] is all I need.",

  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.1-0.ancient": "[sine]Returned again, child of the hammer...[/sine]",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.1-0.next": "Continue",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.1-1.ancient": "[sine]Has your [gold]anvil[/gold] grown cold?[/sine]",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.1-1.next": "Reply",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.1-2.char": "No time for it to cool.",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.1-2.next": "Reply",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.1-3.char": "The next [gold]forging[/gold] is already waiting.",

  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.2-0.ancient": "[sine]A hammer's clang stirs me from sleep...[/sine]",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.2-0.next": "Continue",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.2-1.ancient": "[sine]It has been so long...[/sine]",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.2-1.next": "Apologize",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.2-2.char": "Sorry if I was loud.",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.2-2.next": "Reply",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.2-3.char": "I haven't learned a quiet way to strike yet.",

  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.3-0.ancient": "[sine]Your hands are slowly carving the [gold]way home[/gold]...[/sine]",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.3-0.next": "Nod",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.3-1.char": "Carved or chipped, it's fine.",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.3-1.next": "Reply",
  "NEOW.talk.FRONTIER-SHUMIT_CHARACTER.3-2.char": "It's all [gold]forging[/gold] in the end.",

  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.0-0.ancient": "Oh, a guest with a hammer!",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.0-0.next": "Continue",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.0-1.ancient": "Piles of useful [gold]parts[/gold] just for you!",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.0-1.next": "Look around",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.0-2.char": "Let me see what you've got.",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.0-2.next": "Reply",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.0-3.char": "Whatever's rough, I can always [gold]forge[/gold] into shape.",

  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.1-0.ancient": "Ooh, back again, smith!",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.1-0.next": "Continue",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.1-1.ancient": "Fresh [gold]goods[/gold] came in today!",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.1-1.next": "Thanks",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.1-2.char": "You keep looking out for me.",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.1-2.next": "Reply",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.1-3.char": "Thanks, again.",

  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.2-0.ancient": "You've become a regular!",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.2-0.next": "Continue",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.2-1.ancient": "Let's strike a special [gold]deal[/gold] today!",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.2-1.next": "Interested",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.2-2.char": "I do like a special deal.",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.2-2.next": "Reply",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.2-3.char": "Long as it's something the hammer can use.",

  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.3-0.ancient": "Friend! Today I might show you my [gold]secret[/gold]!",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.3-0.next": "Look around",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.3-1.char": "We're friends now?",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.3-1.next": "Reply",
  "DARV.talk.FRONTIER-SHUMIT_CHARACTER.3-2.char": "Then I'd better take a proper look.",

  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.0-0.ancient": "[thinky_dots]Your hammer... it stirs the [gold]ember[/gold] beneath my scales...[/thinky_dots]",
  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.0-0.next": "Nod",
  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.0-1.char": "...Fire-tenders deserve some respect.",
  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.0-1.next": "Reply",
  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.0-2.char": "Mind lending me a bit of your [gold]heat[/gold]?",

  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.1-0.ancient": "[thinky_dots]Your [gold]heat[/gold] has not scattered...[/thinky_dots]",
  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.1-0.next": "Continue",
  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.1-1.ancient": "[thinky_dots]You tend it well.[/thinky_dots]",
  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.1-1.next": "Reply",
  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.1-2.char": "Less tending, more walking together.",
  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.1-2.next": "Reply",
  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.1-3.char": "Fire dies when you cage it.",

  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.2-0.ancient": "[thinky_dots]My scales are drying...[/thinky_dots]",
  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.2-0.next": "Continue",
  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.2-1.ancient": "[thinky_dots]Could your hammer cool them?[/thinky_dots]",
  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.2-1.next": "Nod",
  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.2-2.char": "I'll strike gently if you need it.",
  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.2-2.next": "Reply",
  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.2-3.char": "Cooling work shouldn't be hit too hard.",

  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.3-0.ancient": "[thinky_dots]Smith, your [gold]ember[/gold] is now as deep as my scales.[/thinky_dots]",
  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.3-0.next": "Careful reply",
  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.3-1.char": "...That's generous.",
  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.3-1.next": "Reply",
  "PAEL.talk.FRONTIER-SHUMIT_CHARACTER.3-2.char": "I'm still on the anvil, you know.",

  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.0-0.ancient": "Too hard! Too hot!",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.0-0.next": "Continue",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.0-1.ancient": "That hammer... scary! Very scary!!",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.0-1.next": "Calm",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.0-2.char": "Easy, I won't swing it.",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.0-2.next": "Reply",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.0-3.char": "Just came to ask the way.",

  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.1-0.ancient": "Again! That hammer again!",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.1-0.next": "Continue",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.1-1.ancient": "Scary! Very scary!",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.1-1.next": "Calm",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.1-2.char": "Same hammer as before.",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.1-2.next": "Reply",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.1-3.char": "I won't swing it, easy now.",

  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.2-0.ancient": "...You... can we be friends??",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.2-0.next": "Promise",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.2-1.char": "Friend or guest, I won't hurt you.",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.2-1.next": "Reply",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.2-2.char": "I'll promise that.",

  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.3-0.ancient": "Hammer friend!",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.3-0.next": "Continue",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.3-1.ancient": "Come back again, even better!",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.3-1.next": "Nod",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.3-2.char": "Glad to hear it.",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.3-2.next": "Reply",
  "OROBAS.talk.FRONTIER-SHUMIT_CHARACTER.3-3.char": "Don't lose your way on the road back.",

  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.0-0.ancient": "An otherworldly [sine]smith[/sine], standing before me.",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.0-0.next": "Continue",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.0-1.ancient": "The road home does not lie at the end of that hammer.",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.0-1.next": "Ask back",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.0-2.char": "...Then where is it?",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.0-2.next": "Reply",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.0-3.char": "Any [gold]answer[/gold] worth carrying, I'll take it.",

  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.1-0.ancient": "[sine]The hammer is no answer.[/sine]",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.1-0.next": "Continue",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.1-1.ancient": "[sine]Yet you keep striking.[/sine]",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.1-1.next": "Ask back",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.1-2.char": "Even if it isn't, the hammer is what fits my hand.",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.1-2.next": "Reply",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.1-3.char": "Not reason enough to put it down.",

  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.2-0.ancient": "[sine]Your [gold]anvil[/gold] does not waver.[/sine]",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.2-0.next": "Continue",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.2-1.ancient": "[sine]How.[/sine]",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.2-1.next": "Reply",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.2-2.char": "If it wavered, I couldn't strike.",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.2-2.next": "Reply",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.2-3.char": "You make nothing on a shaking anvil.",

  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.3-0.ancient": "[sine]Then how far will your hammer reach?[/sine]",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.3-0.next": "Finish",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.3-1.char": "As far as it can.",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.3-1.next": "Reply",
  "VAKUU.talk.FRONTIER-SHUMIT_CHARACTER.3-2.char": "That's the answer of [gold]forging[/gold].",

  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.0-0.ancient": "What a [jitter][b]hot[/b][/jitter] guest! The kiln is always open.",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.0-0.next": "Continue",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.0-1.ancient": "Mind lending some of your [gold]heat[/gold]?",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.0-1.next": "Negotiate",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.0-2.char": "My heat is meant for the hammer.",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.0-2.next": "Reply",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.0-3.char": "You wouldn't send me off empty-handed, right?",

  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.1-0.ancient": "My [jitter]hot[/jitter] guest is back!",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.1-0.next": "Continue",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.1-1.ancient": "The kiln was [b]waiting[/b] for you!",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.1-1.next": "Keep distance",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.1-2.char": "Sweet of you to wait, but it's a bit too hot here.",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.1-2.next": "Reply",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.1-3.char": "I'll stand back a step.",

  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.2-0.ancient": "More! More! Give me your [gold]heat[/gold]!",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.2-0.next": "Continue",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.2-1.ancient": "Take all you want, give it all!",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.2-1.next": "Decline",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.2-2.char": "If I give it all, I go cold.",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.2-2.next": "Reply",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.2-3.char": "Sharing in halves is more like a trade, isn't it?",

  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.3-0.ancient": "...Good. I've never met such a [b]calm[/b] guest.",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.3-0.next": "Continue",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.3-1.ancient": "Name your price.",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.3-1.next": "Negotiate",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.3-2.char": "Not calm, just minding my own heat.",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.3-2.next": "Reply",
  "TEZCATARA.talk.FRONTIER-SHUMIT_CHARACTER.3-3.char": "That's why I trade slowly.",

  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.0-0.ancient": "Quite the hammer, smith!",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.0-0.next": "Continue",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.0-1.ancient": "But true weapons grow from [gold]beasts[/gold]!",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.0-1.next": "Shrug",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.0-2.char": "That's your way. Not mine.",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.0-2.next": "Reply",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.0-3.char": "My work is born on my [gold]anvil[/gold].",

  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.1-0.ancient": "Back again, smith!",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.1-0.next": "Continue",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.1-1.ancient": "Will you spar with my [gold]beasts[/gold] today!",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.1-1.next": "Pass",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.1-2.char": "I'll pass on the beasts.",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.1-2.next": "Reply",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.1-3.char": "No good for either of us, getting hurt.",

  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.2-0.ancient": "Hmph, smith!",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.2-0.next": "Continue",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.2-1.ancient": "I'll give you that [gold]hammer[/gold] of yours, at least!",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.2-1.next": "Nod",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.2-2.char": "Thanks.",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.2-2.next": "Reply",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.2-3.char": "Your beasts look well kept, too.",

  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.3-0.ancient": "Next time, I want to test your hammer [b]for real[/b]!",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.3-0.next": "Shrug",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.3-1.char": "A test is fine, but no real injuries.",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.3-1.next": "Reply",
  "TANX.talk.FRONTIER-SHUMIT_CHARACTER.3-2.char": "For both of us.",

  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.0-0.ancient": "Ah, a visitor with a hammer.",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.0-0.next": "Continue",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.0-1.ancient": "May today's [gold]dice[/gold] favor you.",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.0-1.next": "Cross arms",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.0-2.char": "Wouldn't have brought a hammer if I trusted luck.",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.0-2.next": "Reply",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.0-3.char": "Still, I'll roll once.",

  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.1-0.ancient": "Back again, smith.",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.1-0.next": "Continue",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.1-1.ancient": "Which way will [gold]fortune[/gold] flow today?",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.1-1.next": "Reply",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.1-2.char": "We'll find out when it flows.",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.1-2.next": "Reply",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.1-3.char": "I'll keep hammering in the meantime.",

  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.2-0.ancient": "Your [gold]dice[/gold] always come up even.",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.2-0.next": "Continue",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.2-1.ancient": "You never lean on luck.",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.2-1.next": "Acknowledge",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.2-2.char": "What's at hand is just more reliable.",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.2-2.next": "Reply",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.2-3.char": "Though, when a roll is called for, I'll roll.",

  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.3-0.ancient": "Guests like you are rare.",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.3-0.next": "Continue",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.3-1.ancient": "The [gold]odds[/gold] of meeting again are high, aren't they?",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.3-1.next": "Farewell",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.3-2.char": "High or low, if I'm passing through, I'll stop by.",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.3-2.next": "Reply",
  "NONUPEIPE.talk.FRONTIER-SHUMIT_CHARACTER.3-3.char": "It was a good meeting.",

  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.0-0.ancient": "So, you climbed all the way up here with a single hammer.",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.0-0.next": "Continue",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.0-1.ancient": "Pioneer of an unfamiliar [gold]world[/gold].",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.0-1.next": "Stand firm",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.0-2.char": "...I won't drag this out.",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.0-2.next": "Reply",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.0-3.char": "Open the [gold]door[/gold] home, and I'll wrap this up clean.",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.0-3.next": "Reply",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.0-4.ancient": "The door is already beneath your feet.",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.0-4.next": "Continue",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.0-5.ancient": "The only question is whether you are worthy to [b]pay the price[/b].",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.0-5.next": "Raise the hammer",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.0-6.char": "Prices always get paid on the [gold]anvil[/gold].",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.0-6.next": "Reply",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.0-7.char": "Today's no different.",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.0-7.next": "Final words",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.0-8.ancient": "Very well, smith.",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.0-8.next": "Continue",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.0-9.ancient": "Let a single [jitter]hammer strike[/jitter] settle it.",

  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.1-0.ancient": "You again, hammer-bearer.",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.1-0.next": "Continue",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.1-1.ancient": "You could have gone home. Why return?",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.1-1.next": "Shrug",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.1-2.char": "[gold]Forging[/gold] never ends in one strike.",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.1-2.next": "Reply",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.1-3.char": "Keep hammering till the shape is right.",

  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.2-0.ancient": "By now my face must be familiar.",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.2-0.next": "Continue",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.2-1.ancient": "What do you come to hammer today?",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.2-1.next": "Reply",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.2-2.char": "Today it's [gold]you[/gold] on the anvil.",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.2-2.next": "Reply",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.2-3.char": "Ready?",

  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.3-0.ancient": "The [b]smith's song[/b] rings here again.",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.3-0.next": "Continue",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.3-1.ancient": "Come, one last strike.",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.3-1.next": "Finish",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.3-2.char": "Last? I'll decide that.",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.3-2.next": "Reply",
  "THE_ARCHITECT.talk.FRONTIER-SHUMIT_CHARACTER.3-3.char": "Now, [gold]begin[/gold]."
}
